# Checkpoint middleware enforcement.
# Copy this file to `.env.local` and fill in real values from the Checkpoint
# dashboard → your project → Deployment tab. Do NOT commit real secrets.

# Required — your Checkpoint dashboard/tenant hostname (e.g. acme.kya.vouched.id).
CHECKPOINT_TENANT_HOST=

# Optional — server API key. Enables detections to land in the dashboard.
CHECKPOINT_API_KEY=

# Optional — enables in-process composed Cedar policy enforcement.
CHECKPOINT_PROJECT_ID=
