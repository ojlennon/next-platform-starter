# Checkpoint middleware enforcement.
# Copy this file to `.env.local` and fill in real values from the Checkpoint
# dashboard → your project → Deployment tab. Do NOT commit real secrets.

# Required — server API key used by the Edge-compatible Checkpoint gateway.
# In Netlify, make this available to the Functions scope.
CHECKPOINT_API_KEY=

# Optional — override the Checkpoint gateway URL (normally leave unset).
CHECKPOINT_API_URL=
